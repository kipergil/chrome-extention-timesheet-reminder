<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" width="128" height="128">
  <!-- Background -->
  <rect width="128" height="128" fill="#3498db" rx="24"/>
  
  <!-- Outer circle -->
  <circle cx="64" cy="64" r="50" fill="none" stroke="#fff" stroke-width="3"/>
  
  <!-- Clock hands -->
  <g stroke="#fff" stroke-width="3" stroke-linecap="round">
    <!-- Hour hand -->
    <line x1="64" y1="64" x2="64" y2="40"/>
    <!-- Minute hand -->
    <line x1="64" y1="64" x2="80" y2="48"/>
  </g>
  
  <!-- Center dot -->
  <circle cx="64" cy="64" r="4" fill="#fff"/>
  
  <!-- Numbers -->
  <text x="64" y="28" text-anchor="middle" font-size="12" font-weight="bold" fill="#fff" dominant-baseline="middle">12</text>
  <text x="100" y="67" text-anchor="middle" font-size="12" font-weight="bold" fill="#fff" dominant-baseline="middle">3</text>
  <text x="64" y="100" text-anchor="middle" font-size="12" font-weight="bold" fill="#fff" dominant-baseline="middle">6</text>
  <text x="28" y="67" text-anchor="middle" font-size="12" font-weight="bold" fill="#fff" dominant-baseline="middle">9</text>
</svg>
